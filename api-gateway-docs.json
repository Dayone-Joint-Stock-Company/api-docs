                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "example": "2025-01-01"
                                            }
                                        },
                                        "exclude_recurring_day": {
                                            "description": "Promo non-effective day of week",
                                            "type": "array",
                                            "items": {
                                                "type": "string",
                                                "example": "Tuesday"
                                            }
                                        },
                                        "redeemable_skus": {
                                            "description": "List of redeemable SKUs of the voucher code. For voucher type = conditional, bill number must contain at least 1 redeemable SKU of the voucher.",
