    "components": {
        "schemas": {
            "RequestCheckMultipleBodySchema": {
                "properties": {
                    "pin": {
                        "description": "Store pin",
                        "type": "string",
                        "example": "1212"
                    },
                    "codes": {
                        "description": "Array of 10-16 characters Got It voucher codes",
                        "type": "array",
                        "items": {
                            "type": "string"
                        },
                        "example": [
                            "070898022379",
                            "7132616187"
                        ]
                    },
                    "bill_number": {
                        "description": "Bill number will apply vouchers",
                        "type": "string",
                        "example": "BILL001"
                    },
                    "total_bill": {
                        "description": "Total bill amount",
                        "type": "integer",
                        "example": "1000000"
                    },
                    "skip_reserved_when_mark_used": {
                        "description": "When true the system will execute the flow without reserve",
                        "type": "boolean",
                        "example": true
                    },
                    "skus_info": {
                        "description": "SKU information in bill_number",
                        "type": "array",
                        "items": {
                            "properties": {
                                "sku": {
                                    "description": "SKU code",
                                    "type": "string",
                                    "example": "SKU001"
                                },
                                "quantity": {
                                    "description": "Quantity of SKU. Default = 1",
                                    "type": "integer",
                                    "example": 1
                                },
                                "price": {
                                    "description": "Price of SKU in bill",
                                    "type": "integer",
                                    "example": 100000
                                }
                            },
                            "type": "object"
                        },
                        "example": [
                            {
                                "sku": "SKU001",
                                "quantity": 1,
                                "price": 100000
                            },
                            {
                                "sku": "SKU002",
                                "quantity": 2,
                                "price": 200000
                            }
                        ]
                    }
                },
                "type": "object"
            },
