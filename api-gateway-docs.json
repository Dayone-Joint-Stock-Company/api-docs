                                            "items": {
                                                "type": "string",
                                                "example": "SKU001"
                                            }
                                        }
                                    },
                                    "type": "object"
                                },
                                "redemptions": {
                                    "description": "Include information related to the use of the voucher (all types)",
                                    "properties": {
                                        "redeem_sku_codes": {
                                            "description": "Contains redeemed SKU information of the voucher (for voucher type is conditional and support sku)",
                                            "type": "array",
                                            "items": {
                                                "properties": {
                                                    "sku": {
                                                        "description": "SKU code is redeemed for voucher",
